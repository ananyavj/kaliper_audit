{
  "events": [
    {
      "name": "Signup",
      "required_properties": ["account_id", "plan", "signup_method"],
      "property_types": { "account_id": "string", "plan": "string", "signup_method": "string" },
      "identity_required": true,
      "allowed_previous_events": [],
      "allowed_values": { "plan": ["free", "starter", "pro", "enterprise"] }
    },
    {
      "name": "Login",
      "required_properties": ["method"],
      "property_types": { "method": "string" },
      "identity_required": true,
      "allowed_previous_events": ["Signup"],
      "allowed_values": { "method": ["password", "google", "github", "sso"] }
    },
    {
      "name": "Onboarding Completed",
      "required_properties": ["account_id", "steps_completed"],
      "property_types": { "account_id": "string", "steps_completed": "number" },
      "identity_required": true,
      "allowed_previous_events": ["Signup"]
    },
    {
      "name": "Trial Started",
      "required_properties": ["trial_id", "plan", "trial_length_days"],
      "property_types": { "trial_id": "string", "plan": "string", "trial_length_days": "number" },
      "identity_required": true,
      "allowed_previous_events": ["Signup"],
      "allowed_values": { "plan": ["starter", "pro", "enterprise"] }
    },
    {
      "name": "Feature Used",
      "required_properties": ["feature_name", "account_id"],
      "property_types": { "feature_name": "string", "account_id": "string" },
      "identity_required": true,
      "allowed_previous_events": ["Signup"]
    },
    {
      "name": "Invite Sent",
      "required_properties": ["invitee_email", "account_id"],
      "property_types": { "invitee_email": "string", "account_id": "string" },
      "identity_required": true,
      "allowed_previous_events": ["Signup"]
    },
    {
      "name": "Subscription Started",
      "required_properties": ["subscription_id", "plan", "billing_status", "mrr"],
      "property_types": { "subscription_id": "string", "plan": "string", "billing_status": "string", "mrr": "number" },
      "identity_required": true,
      "allowed_previous_events": ["Trial Started"],
      "allowed_values": {
        "plan": ["starter", "pro", "enterprise"],
        "billing_status": ["active", "past_due", "cancelled"]
      }
    },
    {
      "name": "Subscription Cancelled",
      "required_properties": ["subscription_id", "reason"],
      "property_types": { "subscription_id": "string", "reason": "string" },
      "identity_required": true,
      "allowed_previous_events": ["Subscription Started"]
    }
  ]
}