{
  "events": [
    {
      "name": "Page Viewed",
      "required_properties": ["page_url", "session_id"],
      "property_types": { "page_url": "string", "session_id": "string" },
      "identity_required": false,
      "allowed_previous_events": []
    },
    {
      "name": "Product Viewed",
      "required_properties": ["product_id", "title", "price"],
      "property_types": { "product_id": "string", "title": "string", "price": "number" },
      "identity_required": false,
      "allowed_previous_events": ["Page Viewed"]
    },
    {
      "name": "Product Added",
      "required_properties": ["product_id", "quantity", "price"],
      "property_types": { "product_id": "string", "quantity": "number", "price": "number" },
      "identity_required": true,
      "allowed_previous_events": ["Product Viewed"]
    },
    {
      "name": "Wishlist Added",
      "required_properties": ["product_id"],
      "property_types": { "product_id": "string" },
      "identity_required": true,
      "allowed_previous_events": ["Product Viewed"]
    },
    {
      "name": "Coupon Applied",
      "required_properties": ["coupon_code", "discount_amount"],
      "property_types": { "coupon_code": "string", "discount_amount": "number" },
      "identity_required": true,
      "allowed_previous_events": ["Checkout Started"]
    },
    {
      "name": "Checkout Started",
      "required_properties": ["cart_id", "revenue", "currency"],
      "property_types": { "cart_id": "string", "revenue": "number", "currency": "string" },
      "identity_required": true,
      "allowed_previous_events": ["Product Added"],
      "allowed_values": { "currency": ["INR", "USD", "AED", "GBP"] }
    },
    {
      "name": "Checkout Step Viewed",
      "required_properties": ["cart_id", "step"],
      "property_types": { "cart_id": "string", "step": "number" },
      "identity_required": true,
      "allowed_previous_events": ["Checkout Started"]
    },
    {
      "name": "Order Completed",
      "required_properties": ["order_id", "revenue", "currency"],
      "property_types": { "order_id": "string", "revenue": "number", "currency": "string" },
      "identity_required": true,
      "allowed_previous_events": ["Checkout Started"],
      "allowed_values": { "currency": ["INR", "USD", "AED"] }
    },
    {
      "name": "Order Refunded",
      "required_properties": ["order_id", "refund_amount"],
      "property_types": { "order_id": "string", "refund_amount": "number" },
      "identity_required": true,
      "allowed_previous_events": ["Order Completed"]
    }
  ]
}